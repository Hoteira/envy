<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.envy.dotenv</id>

    <name>EnvY</name>
    <vendor email="hoteira@proton.me" url="https://github.com/Hoteira">Hoteira</vendor>

    <depends>com.intellij.modules.lang</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="DotEnv"
                language="DotEnv"
                implementationClass="com.envy.dotenv.language.DotEnvFileType"
                fieldName="INSTANCE"
                fileNames=".env;.envrc"
                patterns=".env.*"
        />

        <toolWindow
                id="Env Diff"
                anchor="bottom"
                factoryClass="com.envy.dotenv.toolWindow.EnvDiffToolWindowFactory"/>

        <lang.parserDefinition
                language="DotEnv"
                implementationClass="com.envy.dotenv.language.DotEnvParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="DotEnv"
                implementationClass="com.envy.dotenv.language.DotEnvSyntaxHighlighterFactory"/>

        <localInspection
                language="DotEnv"
                displayName="Duplicate key in .env file"
                groupName="DotEnv"
                shortName="DotEnvDuplicateKey"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="com.envy.dotenv.inspections.DuplicateKeyInspection"/>

        <localInspection
                language="DotEnv"
                displayName="Possible secret or credential in .env file"
                groupName="DotEnv"
                shortName="DotEnvSecretLeak"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="com.envy.dotenv.inspections.SecretLeakInspection"/>

        <lang.foldingBuilder
                language="DotEnv"
                implementationClass="com.envy.dotenv.language.DotEnvFoldingBuilder"/>

        <localInspection
                language="DotEnv"
                displayName="Secret value hidden in presentation mode"
                groupName="DotEnv"
                shortName="DotEnvPresentationMode"
                enabledByDefault="true"
                level="INFORMATION"
                implementationClass="com.envy.dotenv.inspections.PresentationModeInspection"/>

        <vfs.asyncListener
                implementation="com.envy.dotenv.listeners.GitignoreListener"/>

        <inline.completion.provider
                implementation="com.envy.dotenv.completion.EnvVarInlineCompletionProvider"/>

        <completion.contributor
                language="any"
                implementationClass="com.envy.dotenv.completion.EnvVarCompletionContributor"/>

        <postStartupActivity
                implementation="com.envy.dotenv.terminal.TerminalSecretCensorInitializer"/>

        <consoleInputFilterProvider
                implementation="com.envy.dotenv.terminal.ConsoleSecretRedactionProvider"/>

        <editorNotificationProvider
                implementation="com.envy.dotenv.settings.EnvSettingsEditorNotification"/>

        <editorNotificationProvider
                implementation="com.envy.dotenv.sops.SopsEditorNotification"/>

        <fileEditorProvider
                implementation="com.envy.dotenv.sops.SopsSplitEditorProvider"/>

    </extensions>

    <applicationListeners>
        <listener class="com.envy.dotenv.listeners.DotEnvPresentationModeListener"
                  topic="com.intellij.ide.ui.UISettingsListener"/>
    </applicationListeners>

    <product-descriptor
            code="PENVY"
            release-date="20260426"
            release-version="30"
            optional="true"/>

    <actions>
        <action id="EnvY.ToggleTerminalSecrets"
                class="com.envy.dotenv.terminal.ToggleTerminalSecretsAction"
                text="Toggle Terminal Secrets Visibility"
                description="Reveals or hides censored secrets in the terminal">
            <keyboard-shortcut first-keystroke="ctrl alt shift X" keymap="$default"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>

</idea-plugin>
